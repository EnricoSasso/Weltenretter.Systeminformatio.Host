@page "/personen"
@inject Weltenretter.Systeminformationen.Host.z_Systeminformationen_HostService HostService
@inject DialogService DialogService
@inject NotificationService NotificationService

<PageTitle>Personen</PageTitle>

<RadzenStack Gap="1rem">
    <RadzenRow AlignItems="AlignItems.Center">
        <RadzenColumn Size="12" SizeMD="6">
            <RadzenText Text="Personen" TextStyle="TextStyle.H3" TagName="TagName.H1" />
        </RadzenColumn>
        <RadzenColumn Size="12" SizeMD="6">
            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" JustifyContent="JustifyContent.End" Gap="0.5rem">
                <RadzenButton Icon="add_circle" Text="Neu" Click="@NeuPerson" Variant="Variant.Flat" />
            </RadzenStack>
        </RadzenColumn>
    </RadzenRow>

    <RadzenDataGrid @ref="grid"
                    Data="@personen"
                    Count="@anzahl"
                    LoadData="@LoadData"
                    TItem="Weltenretter.Systeminformationen.Host.Models.Person"
                    AllowPaging="true"
                    AllowSorting="true"
                    AllowFiltering="true"
                    PageSize="10"
                    EditMode="DataGridEditMode.Single"
                    RowUpdate="@OnUpdateRow"
                    RowCreate="@OnCreateRow"
                    RowCancel="@((Weltenretter.Systeminformationen.Host.Models.Person person) => OnCancelRow(person))">
        <Columns>
            <RadzenDataGridColumn TItem="Weltenretter.Systeminformationen.Host.Models.Person" Property="Id" Title="Id" Width="80px" />
            <RadzenDataGridColumn TItem="Weltenretter.Systeminformationen.Host.Models.Person" Property="Vorname" Title="Vorname">
                <EditTemplate Context="person">
                    <RadzenTextBox @bind-Value="person.Vorname" Style="width:100%" Name="Vorname" />
                    <RadzenRequiredValidator Component="Vorname" Text="Vorname ist erforderlich" Popup="true" />
                </EditTemplate>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="Weltenretter.Systeminformationen.Host.Models.Person" Property="Nachname" Title="Nachname">
                <EditTemplate Context="person">
                    <RadzenTextBox @bind-Value="person.Nachname" Style="width:100%" Name="Nachname" />
                    <RadzenRequiredValidator Component="Nachname" Text="Nachname ist erforderlich" Popup="true" />
                </EditTemplate>
            </RadzenDataGridColumn>
            <RadzenDataGridColumn TItem="Weltenretter.Systeminformationen.Host.Models.Person" Title="Aktionen" Width="140px" Filterable="false" Sortable="false">
                <Template Context="person">
                    <RadzenButton Icon="edit" Size="ButtonSize.Small" Variant="Variant.Flat" Click="@(() => BearbeitenRow(person))" />
                    <RadzenButton Icon="delete" Size="ButtonSize.Small" Variant="Variant.Flat" ButtonStyle="ButtonStyle.Danger" Click="@(() => LoeschenRow(person))" />
                </Template>
                <EditTemplate Context="person">
                    <RadzenButton Icon="save" Size="ButtonSize.Small" Variant="Variant.Flat" Click="@(() => grid.UpdateRow(person))" />
                    <RadzenButton Icon="cancel" Size="ButtonSize.Small" Variant="Variant.Flat" ButtonStyle="ButtonStyle.Light" Click="@(() => grid.CancelEditRow(person))" />
                </EditTemplate>
            </RadzenDataGridColumn>
        </Columns>
    </RadzenDataGrid>
</RadzenStack>

@code {
    private RadzenDataGrid<Weltenretter.Systeminformationen.Host.Models.Person>? grid;
    private IEnumerable<Weltenretter.Systeminformationen.Host.Models.Person> personen = Array.Empty<Weltenretter.Systeminformationen.Host.Models.Person>();
    private int anzahl;
    private Weltenretter.Systeminformationen.Host.Models.Person? personToInsert;

    private async Task LoadData(LoadDataArgs args)
    {
        var query = new Query
        {
            Skip = args.Skip,
            Top = args.Top,
            OrderBy = args.OrderBy,
            Filter = args.Filter
        };

        personen = await HostService.GetPersonen(query);
        anzahl = await HostService.GetPersonenCount(query);
    }

    private async Task NeuPerson()
    {
        personToInsert = new Weltenretter.Systeminformationen.Host.Models.Person();
        await grid!.InsertRow(personToInsert);
    }

    private async Task BearbeitenRow(Weltenretter.Systeminformationen.Host.Models.Person person)
    {
        await grid!.EditRow(person);
    }

    private async Task LoeschenRow(Weltenretter.Systeminformationen.Host.Models.Person person)
    {
        try
        {
            await HostService.DeletePerson(person.Id);
            await grid!.Reload();

            NotificationService.Notify(new NotificationMessage
            {
                Severity = NotificationSeverity.Success,
                Summary = "Gelöscht",
                Detail = "Person wurde gelöscht",
                Duration = 3000
            });
        }
        catch (Exception ex)
        {
            NotificationService.Notify(new NotificationMessage
            {
                Severity = NotificationSeverity.Error,
                Summary = "Fehler",
                Detail = ex.Message,
                Duration = 5000
            });
        }
    }

    private async Task OnCreateRow(Weltenretter.Systeminformationen.Host.Models.Person person)
    {
        try
        {
            await HostService.CreatePerson(person);
            personToInsert = null;
            await grid!.Reload();

            NotificationService.Notify(new NotificationMessage
            {
                Severity = NotificationSeverity.Success,
                Summary = "Gespeichert",
                Detail = "Person wurde angelegt",
                Duration = 3000
            });
        }
        catch (Exception ex)
        {
            NotificationService.Notify(new NotificationMessage
            {
                Severity = NotificationSeverity.Error,
                Summary = "Fehler",
                Detail = ex.Message,
                Duration = 5000
            });
        }
    }

    private async Task OnUpdateRow(Weltenretter.Systeminformationen.Host.Models.Person person)
    {
        try
        {
            if (personToInsert == person)
            {
                await HostService.CreatePerson(person);
                personToInsert = null;
            }
            else
            {
                await HostService.UpdatePerson(person.Id, person);
            }

            await grid!.Reload();

            NotificationService.Notify(new NotificationMessage
            {
                Severity = NotificationSeverity.Success,
                Summary = "Gespeichert",
                Detail = "Person wurde gespeichert",
                Duration = 3000
            });
        }
        catch (Exception ex)
        {
            NotificationService.Notify(new NotificationMessage
            {
                Severity = NotificationSeverity.Error,
                Summary = "Fehler",
                Detail = ex.Message,
                Duration = 5000
            });
        }
    }

    private async Task OnCancelRow(Weltenretter.Systeminformationen.Host.Models.Person person)
    {
        if (personToInsert == person)
        {
            personToInsert = null;
        }

        grid!.CancelEditRow(person);
    }
}
