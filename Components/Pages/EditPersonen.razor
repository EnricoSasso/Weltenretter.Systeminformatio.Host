@page "/edit-personen"
@inject IJSRuntime JSRuntime
@inject NavigationManager NavigationManager
@inject DialogService DialogService
@inject ContextMenuService ContextMenuService
@inject TooltipService TooltipService
@inject NotificationService NotificationService

@inject z_Systeminformationen_HostService z_Systeminformationen_HostService

<PageTitle>Edit Personen</PageTitle>

    <RadzenColumn SizeMD=12>
        <RadzenAlert Shade="Shade.Lighter" Variant="Variant.Flat" Size="AlertSize.Small" AlertStyle="AlertStyle.Danger" Visible="@errorVisible">Cannot save Personen</RadzenAlert>
        <RadzenTemplateForm TItem="Weltenretter.Systeminformationen.Host.Models.z_Systeminformationen_Host.Personen" Data="@(personen)" Visible="@(personen != null)" Submit="@FormSubmit">
            <RadzenRow style="margin-bottom: 1rem">
                <RadzenColumn SizeMD="3">
                    <RadzenLabel Text="Vorname" Component="Vorname" style="width: 100%" />
                </RadzenColumn>
                <RadzenColumn SizeMD="9">
                    <RadzenTextBox style="display: block; width: 100%" @bind-Value="@(personen.Vorname)" Name="Vorname" />
                    <RadzenRequiredValidator Component="Vorname" Text="Vorname is required" />
                </RadzenColumn>
            </RadzenRow>
            <RadzenRow style="margin-bottom: 1rem">
                <RadzenColumn SizeMD="3">
                    <RadzenLabel Text="Nachname" Component="Nachname" style="width: 100%" />
                </RadzenColumn>
                <RadzenColumn SizeMD="9">
                    <RadzenTextBox style="display: block; width: 100%" @bind-Value="@(personen.Nachname)" Name="Nachname" />
                    <RadzenRequiredValidator Component="Nachname" Text="Nachname is required" />
                </RadzenColumn>
            </RadzenRow>
          <RadzenStack  Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" JustifyContent="JustifyContent.End" Gap="0.5rem">
                    <RadzenButton ButtonStyle="ButtonStyle.Primary" ButtonType="ButtonType.Submit" Icon="save" Text="Save" Variant="Variant.Flat" />
                    <RadzenButton ButtonStyle="ButtonStyle.Light" Text="Cancel" Variant="Variant.Flat" Click="@CancelButtonClick"  />
          </RadzenStack>
        </RadzenTemplateForm>
    </RadzenColumn>

@code {

    [Parameter]
    public int Id { get; set; }

    protected override async Task OnInitializedAsync()
    {
        personen = await z_Systeminformationen_HostService.GetPersonenById(Id);
    }
    protected bool errorVisible;
    protected Weltenretter.Systeminformationen.Host.Models.z_Systeminformationen_Host.Personen personen;

    protected async Task FormSubmit()
    {
        try
        {
            await z_Systeminformationen_HostService.UpdatePersonen(Id, personen);
            DialogService.Close(personen);
        }
        catch (Exception ex)
        {
            errorVisible = true;
        }
    }

    protected async Task CancelButtonClick(MouseEventArgs args)
    {
        DialogService.Close(null);
    }
}
